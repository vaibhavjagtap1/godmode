{
  "name": "behindtheemail",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @behindtheemail/api run dev",
    "dev:web": "npm --workspace @behindtheemail/web run dev",
    "build": "npm-run-all build:api build:web",
    "build:api": "npm --workspace @behindtheemail/api run build",
    "build:web": "npm --workspace @behindtheemail/web run build",
    "test": "npm --workspace @behindtheemail/api run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
